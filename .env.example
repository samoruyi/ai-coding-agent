# =============================================================
# Coding Agent Platform - environment variables
# Copy to .env for local docker-compose dev, or feed into
# AWS Secrets Manager / Helm values for cluster deployments.
# =============================================================

# ---- LLM provider (Pydantic AI) ----
# AGENT_MODEL examples: "anthropic:claude-opus-4-7", "openai:gpt-4o-mini"
AGENT_MODEL=anthropic:claude-opus-4-7
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Temporal ----
# For local docker-compose: temporal:7233 (no TLS, no namespace auth)
# For Temporal Cloud: <namespace>.<account>.tmprl.cloud:7233 + mTLS
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=coding-agent
TEMPORAL_TLS=false
# Path to client cert/key when TEMPORAL_TLS=true (mounted as a Secret in k8s)
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=

# ---- Slack ----
# Create at https://api.slack.com/apps  (Bot Token Scopes: app_mentions:read,
# chat:write, chat:write.public, channels:history). Subscribe to app_mention.
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
# Set to "true" in dev to use Socket Mode instead of public HTTPS endpoint
SLACK_SOCKET_MODE=false
SLACK_APP_TOKEN=xapp-REPLACE_ME_only_when_socket_mode_true

# ---- GitHub ----
# Set GITHUB_MODE=mock to use the in-memory mock implementation,
# or GITHUB_MODE=real to use a Personal Access Token / GitHub App.
GITHUB_MODE=mock
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# ---- Service ----
LOG_LEVEL=INFO
SLACK_GATEWAY_PORT=8080
# Workspace root for agent scratch dirs (per-workflow isolated subdirs)
AGENT_WORKSPACE_ROOT=/var/agent/workspaces

# ---- Safety rails ----
AGENT_MAX_ITERATIONS=20
AGENT_TIMEOUT_SECONDS=900
AGENT_SHELL_ALLOWLIST=ls,cat,head,tail,wc,grep,rg,find,git,python,python3,pytest,node,npm,pnpm
